<%-
  # ---------------------------------------------------------------------------
  # Phase A: launch a fixed Jupyter image in the Cirrus Kubernetes cluster.
  #
  # The init containers (from the ood-k8s-utils image) do three things before
  # Jupyter starts:
  #   1. generate a one-time password and store it as a k8s secret
  #   2. inject the hashed password into the notebook config (configmap)
  #   3. inject the OnDemand reverse-proxy base_url (/node/HOST/PORT/)
  # OnDemand reads back the host/port/password to render the Connect button.
  #
  # NOTE on the two `add-line-to-configmap` calls below: the value being
  # written needs single quotes to survive as a valid Python string literal,
  # and $SALT/$PASSWORD_SHA1/$HOST_CFG/$PORT_CFG need to expand at container
  # runtime -- which means they can't be wrapped in single quotes themselves.
  # Wrapping them in double quotes (the original approach) works fine for
  # *this* file's own YAML, but ood_core's pod.yml.erb later re-embeds this
  # whole command string inside ANOTHER double-quoted YAML scalar without
  # escaping it -- so any literal " we put here collides with that outer
  # wrapping and breaks the generated manifest (the "did not find expected
  # key" error). Building the apostrophe at runtime via `printf` with an
  # octal escape avoids ever writing a literal " in this file, so there's
  # nothing for the outer template to collide with. See the backslash count
  # below carefully -- it's doubled because the same blind, unescaped
  # substitution happens twice (this file's YAML parse, then pod.yml.erb's),
  # and each pass un-escapes one level. Verified empirically; don't "simplify"
  # the backslash count without re-testing end to end.
  # ---------------------------------------------------------------------------
  configmap_filename = "ondemand_config.py"
  # Public mirror of OSC's helper image. Pin a real tag before production use.
  utility_img = "docker.io/ohiosupercomputer/ood-k8s-utils:latest"
  user = OodSupport::User.new
-%>
---
script:
  wall_time: "<%= wall_time.to_i * 3600 %>"
  native:
    container:
      name: "jupyter"
      image: "quay.io/jupyter/scipy-notebook:latest"
      command: "/usr/local/bin/start.sh jupyter notebook --config=/ood/ondemand_config.py"
      working_dir: "<%= user.home %>"
      restart_policy: "OnFailure"
      env:
        NB_UID: "<%= user.uid %>"
        NB_USER: "<%= user.name %>"
        NB_GID: "<%= user.group.id %>"
        HOME: "<%= user.home %>"
      port: 8080
      cpu: "<%= cpu %>"
      memory: "<%= memory %>Gi"
    configmap:
      files:
        - filename: "<%= configmap_filename %>"
          data: |
            c.NotebookApp.port = 8080
            c.NotebookApp.ip = '0.0.0.0'
            c.NotebookApp.disable_check_xsrf = True
            c.NotebookApp.allow_origin = '*'
            c.Application.log_level = 'DEBUG'
          mount_path: "/ood"
    mounts:
      - type: host
        name: home
        host_type: Directory
        path: "<%= user.home %>"
        destination_path: "<%= user.home %>"
    init_containers:
      - name: "init-secret"
        image: "<%= utility_img %>"
        command:
          - "/bin/save_passwd_as_secret"
          - "user-<%= user.name %>"
      - name: "add-passwd-to-cfg"
        image: "<%= utility_img %>"
        command:
          - "/bin/bash"
          - "-c"
          - "source /bin/passwd_from_secret; source /bin/create_salt_and_sha1; Q=$(printf '\\\\047'); /bin/add_line_to_configmap c.NotebookApp.password=u${Q}sha1:${SALT}:${PASSWORD_SHA1}${Q} <%= configmap_filename %>"
      - name: "add-hostport-to-cfg"
        image: "<%= utility_img %>"
        command:
          - "/bin/bash"
          - "-c"
          - "source /bin/find_host_port; Q=$(printf '\\\\047'); /bin/add_line_to_configmap c.NotebookApp.base_url=${Q}/node/${HOST_CFG}/${PORT_CFG}/${Q} <%= configmap_filename %>"